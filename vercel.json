   "source": [
    "{\n",
    "  \"buildCommand\": \"cd backend && pip install -r requirements.txt\",\n",
    "  \"outputDirectory\": \"backend\",\n",
    "  \"framework\": \"python\",\n",
    "  \"env\": {\n",
    "    \"PYTHONUNBUFFERED\": \"1\"\n",
    "  },\n",
    "  \"functions\": {\n",
    "    \"backend/main.py\": {\n",
    "      \"runtime\": \"python3.11\"\n",
    "    }\n",
    "  },\n",
    "  \"routes\": [\n",
    "    {\n",
    "      \"src\": \"/(.*)\",\n",
    "      \"dest\": \"backend/main.py\"\n",
    "    }\n",
    "  ]\n",
    "}"
   ]
  }
